# Machine-specific settings — copy to .env and adjust for your machine.
#
# Data lives in data/ (managed by DVC). After cloning, set up the cache
# and pull data:
#
#   uv run dvc cache dir /path/to/dvc-cache    # outside sync/backup dirs
#   uv run dvc pull                             # download from remote
#
# Example cache paths:
#   doudou:  /home/haduong/data/projets/Oeconomia-Climate-finance/dvc-cache
#   padme:   /data/projets/dvc-cache/oeconomia-climate-finance

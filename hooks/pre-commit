#!/bin/sh
# Pre-commit guards — keep the repo clean. No overrides.

# 1. No commits on main
branch=$(git rev-parse --abbrev-ref HEAD)
if [ "$branch" = "main" ]; then
    echo "ERROR: Direct commits to main are not allowed. Work on a branch." >&2
    exit 1
fi

# 1b. No merges on submission branches (use cherry-pick instead)
case "$branch" in
    submission/*)
        if [ -f "$(git rev-parse --git-dir)/MERGE_HEAD" ]; then
            echo "ERROR: No merges on submission branches — use git cherry-pick." >&2
            exit 1
        fi
        ;;
esac

# 2. CLAUDE.md is locked
if git diff --cached --name-only | grep -qx 'CLAUDE.md'; then
    echo "ERROR: CLAUDE.md is protected. Edit AGENTS.md instead." >&2
    exit 1
fi

# 3. No secrets
secrets=$(git diff --cached --name-only | grep -iE '\.env$|\.env\.|credentials|secret|api.?key|\.pem$|\.key$' || true)
if [ -n "$secrets" ]; then
    echo "ERROR: Possible secrets staged:" >&2
    echo "$secrets" >&2
    exit 1
fi

# 4. No large files (>500KB), except uv.lock (grows with CUDA wheel metadata)
large=$(git diff --cached --name-only --diff-filter=d | while IFS= read -r file; do
    case "$file" in uv.lock) continue ;; esac
    case "$file" in content/tables/*.csv) continue ;; esac
    size=$(wc -c < "$file" 2>/dev/null || echo 0)
    if [ "$size" -gt 512000 ]; then
        printf '  %s (%dKB)\n' "$file" "$(( size / 1024 ))"
    fi
done)
if [ -n "$large" ]; then
    echo "ERROR: Large files staged (>500KB):" >&2
    echo "$large" >&2
    exit 1
fi

# 5. No conflict markers
conflicts=$(git diff --cached --name-only -z | xargs -0 grep -l '^<<<<<<<\|^>>>>>>>\|^=======$' 2>/dev/null || true)
if [ -n "$conflicts" ]; then
    echo "ERROR: Unresolved merge conflict markers in:" >&2
    echo "$conflicts" >&2
    exit 1
fi

# 6. Validate .ticket files (if any are staged)
ticket_files=$(git diff --cached --name-only | grep '\.ticket$' || true)
if [ -n "$ticket_files" ]; then
    ticket_bin="tickets/tools/go/ticket-tools"
    if [ -x "$ticket_bin" ]; then
        if ! "$ticket_bin" validate tickets/; then
            echo "ERROR: Ticket validation failed. Fix errors above." >&2
            exit 1
        fi
    else
        # Fall back to Python validator
        if command -v python3 >/dev/null 2>&1; then
            if ! PYTHONPATH=tickets/tools python3 tickets/tools/validate_tickets.py tickets/; then
                echo "ERROR: Ticket validation failed. Fix errors above." >&2
                exit 1
            fi
        else
            echo "ERROR: No ticket validator available (build with 'make ticket-build' or install python3)." >&2
            exit 1
        fi
    fi
fi

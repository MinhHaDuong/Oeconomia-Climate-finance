#!/bin/sh
# Symlink .env from main worktree into new worktrees
# .env is gitignored (machine-specific paths), but scripts need it

if [ ! -e .env ]; then
    main_worktree=$(git worktree list --porcelain | head -1 | sed 's/^worktree //')
    if [ -f "$main_worktree/.env" ]; then
        ln -s "$main_worktree/.env" .env
        echo "Linked .env from main worktree"
    fi
fi

# Populate DVC-managed data from local cache
if [ -f dvc.lock ]; then
    uv run dvc checkout 2>/dev/null || true
fi

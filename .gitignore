# Old drafts
attic/

# Large data (484 PDFs + zip)
corpus ISTEX/

# PDFs in bibliography (keep .bib only)
content/bibliography/*.pdf

# Binary document formats (MD versions tracked instead)
*.odt
*.docx
*.pdf

# Machine-specific data path (see .env.example)
.env

# Data directory — DVC manages catalog/pool artifacts (*.dvc files tracked by git)
# Non-DVC subdirs (raw/) gitignored here; exports/ managed by data/exports.dvc
# syllabi/ managed by data/syllabi.dvc
# teaching_sources.yaml is generated by build_teaching_yaml.py
data/raw/
data/teaching_sources.yaml
# Script checkpoint files (resume state, not source of truth)
data/catalogs/.citations_batch_checkpoint.csv

# Generated figures, tables, and stats (regenerate with: make figures / make stats)
content/figures/
content/tables/
_variables.yml

# Python / uv
.venv/
__pycache__/
*.pyc
.mypy_cache/
.cache/

# Replication archive
*.tar.gz

# Generated reference list (regenerate with: uv run python scripts/gen_missing_references.py)
docs/missing_references.txt

# DOI-fetch stub (real tool lives at ~/CNRS/code/DOI-fetch/)
code/doifetch/

# OS and editor artifacts
.DS_Store
*~
*.swp

# Claude Code config
.claude/


/.quarto/

# Quarto output directory and HTML test renders
output/
*.html
*_files/

**/*.quarto_ipynb
